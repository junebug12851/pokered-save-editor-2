# This file is used to ignore files which are generated
# ----------------------------------------------------------------------------

*~
*.autosave
*.a
*.core
*.moc
*.o
*.obj
*.orig
*.rej
*.so
*.so.*
*_pch.h.cpp
*_resource.rc
*.qm
.#*
*.*#
core
!core/
tags
.DS_Store
.directory
*.debug
Makefile*
*.prl
*.app
moc_*.cpp
ui_*.h
qrc_*.cpp
Thumbs.db
*.res
*.rc
/.qmake.cache
/.qmake.stash

# qtcreator generated files
*.pro.user*
CMakeLists.txt.user*

# xemacs temporary files
*.flc

# Vim temporary files
.*.swp

# Visual Studio generated files
*.ib_pdb_index
*.idb
*.ilk
*.pdb
*.sln
*.suo
*.vcproj
*vcproj.*.*.user
*.ncb
*.sdf
*.opensdf
*.vcxproj
*vcxproj.*

# MinGW generated files
*.Debug
*.Release

# Python byte code
*.pyc

# Binaries
# --------
*.dll
*.exe

# Sensitive Files that cannot be released
# -------
*.gb
*.sym
no-git/

# Build Artifacts
/build-*/
# Build output directories (any depth) — Qt Creator / CMake
build/
projects/build/

# Local build/CI helper scripts & logs at the repo root (machine-specific paths,
# regenerated; never meant to be tracked). Underscore-prefixed by convention.
/_*.bat
/_*.log

# Generated documentation (Doxygen). The Doxyfile and the vendored theme under
# docs/doxygen-awesome/ ARE tracked; only the generated HTML is ignored.
/docs/html/

# Read-only reference clones — the fairyfox.io hub mesh plus other repos pulled
# in for reference (the pret/pokered disassembly, the v1 editor, etc.). These are
# throwaway shallow clones living under assets/references/ and must NEVER be
# tracked (committing them nests repos and bloats history). A pull here produces
# no commit, so it triggers nothing downstream. See
# notes/reference/cross-project-sync.md.
/assets/references/
