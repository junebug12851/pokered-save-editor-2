// pse_version.h -- AUTO-GENERATED by CMake (PSEVersion). DO NOT EDIT.
//
// The single source of truth is the repo-root VERSION file; the git commit
// metadata is filled in at build time. See notes/reference/versioning.md.
#pragma once

// Numeric SemVer components.
#define PSE_VERSION_MAJOR @PSE_VERSION_MAJOR@
#define PSE_VERSION_MINOR @PSE_VERSION_MINOR@
#define PSE_VERSION_PATCH @PSE_VERSION_PATCH@

// People-facing SemVer string: core + optional "-prerelease", no build metadata.
// e.g. "0.7.0-alpha"  (this is what release builds show).
#define PSE_VERSION_STRING "@PSE_VERSION_HUMAN@"

// Git build identity for THIS build. Hash is empty for builds made outside a
// git work tree (e.g. a source tarball); dirty is 1 when the tree had
// uncommitted tracked changes at build time.
#define PSE_GIT_HASH  "@PSE_GIT_HASH@"
#define PSE_GIT_DIRTY @PSE_GIT_DIRTY_BOOL@

// Full version: people-facing string plus "+g<hash>[.dirty]" build metadata
// when built from git. e.g. "0.7.0-alpha+g1a2b3c4d" (dev) or "0.7.0" (release).
// This is what gets set as the app's runtime QApplication version.
#define PSE_VERSION_FULL "@PSE_VERSION_FULL@"
