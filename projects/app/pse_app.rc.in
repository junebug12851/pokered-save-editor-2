// pse_app.rc -- AUTO-GENERATED by CMake from pse_app.rc.in. DO NOT EDIT.
// Embeds a standard Windows VERSIONINFO block so the .exe's
// Properties -> Details shows the version. Numbers come from VERSION.
#include <windows.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @PSE_VERSION_MAJOR@,@PSE_VERSION_MINOR@,@PSE_VERSION_PATCH@,0
 PRODUCTVERSION @PSE_VERSION_MAJOR@,@PSE_VERSION_MINOR@,@PSE_VERSION_PATCH@,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         0x40004L
 FILETYPE       0x1L
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Twilight"
            VALUE "FileDescription",  "Pokered Save Editor"
            VALUE "FileVersion",      "@PSE_VERSION_FULL@"
            VALUE "InternalName",     "PokeredSaveEditor"
            VALUE "LegalCopyright",   "Copyright (C) 2017-2026 Twilight. Apache License 2.0."
            VALUE "OriginalFilename", "PokeredSaveEditor.exe"
            VALUE "ProductName",      "Pokered Save Editor"
            VALUE "ProductVersion",   "@PSE_VERSION_FULL@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
